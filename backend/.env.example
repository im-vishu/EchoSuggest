# MongoDB (match docker-compose credentials or use mongodb://localhost:27017 for local without auth)
MONGODB_URI=mongodb://echosuggest:echosuggest_dev@localhost:27017/?authSource=admin
MONGODB_DB_NAME=echosuggest

# Redis (used in later phases; optional for Phase 1)
REDIS_URL=redis://localhost:6380/0

API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Hybrid recommendation cache (Redis; optional if Redis down)
RECOMMEND_CACHE_TTL_SECONDS=300

# Precompute job: TTL for trending JSON keys in Redis (seconds)
PRECOMPUTE_TTL_SECONDS=3600

# Background precompute interval; 0 = disabled (use POST /api/v1/jobs/precompute)
PRECOMPUTE_SCHEDULE_SECONDS=0

# Optional: require this value in X-API-Key for POST /api/v1/jobs/precompute
# ADMIN_API_KEY=

# JWT for Phase 8 auth (use a long random string in production)
JWT_SECRET=dev-change-me-use-long-random-string-in-production
JWT_ACCESS_EXPIRE_MINUTES=10080
