# MongoDB (match docker-compose credentials or use mongodb://localhost:27017 for local without auth)
MONGODB_URI=mongodb://echosuggest:echosuggest_dev@localhost:27017/?authSource=admin
MONGODB_DB_NAME=echosuggest

# Redis (used in later phases; optional for Phase 1)
REDIS_URL=redis://localhost:6380/0

API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Hybrid recommendation cache (Redis; optional if Redis down)
RECOMMEND_CACHE_TTL_SECONDS=300
